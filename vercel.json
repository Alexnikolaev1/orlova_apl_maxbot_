{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "api/webhook.py"
    },
    {
      "src": "/",
      "dest": "api/webhook.py"
    }
  ],
  "env": {
    "BOT_TOKEN": "@bot_token",
    "GALINA_CHAT_ID": "@galina_chat_id",
    "GALINA_TELEGRAM_LINK": "@galina_telegram_link"
  }
}

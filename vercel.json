{
  "version": 2,
  "builds": [
    {
      "src": "webhook.py",
      "use": "@vercel/python"
    },
    {
      "src": "max_webhook.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "webhook.py"
    },
    {
      "src": "/api/max-webhook",
      "dest": "max_webhook.py"
    },
    {
      "src": "/",
      "dest": "webhook.py"
    }
  ]
}
